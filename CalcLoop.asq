hidecli
clear-usrvars
$button Add
$button Subtract
$button Divide
$button Multiply
$label Result:
$input 0
$input 0
$b-0 out add {$5} {$6}; $l-4 Result: {out};
$b-1 out sub {$5} {$6}; $l-4 Result: {out};
$b-2 out div {$5} {$6}; $l-4 Result: {out};
$b-3 out mul {$5} {$6}; $l-4 Result: {out};
flowform Calculator^Sigma 500 500 vars
showcli
clear-usrvars
runscript-web https://raw.githubusercontent.com/Megamer-studios/AquaScript/refs/heads/master/CalcLoop.asq
